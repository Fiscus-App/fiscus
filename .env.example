# ─── Database ─────────────────────────────────────────────────────────────────
# Get a free PostgreSQL URL from Neon (recommended): https://neon.tech
# Or Supabase: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL="postgresql://user:password@host:5432/fiscus?sslmode=require"

# ─── Anthropic AI ─────────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Cron Security ────────────────────────────────────────────────────────────
# Any random string. Set the same value in:
#   - Vercel: Environment Variables → CRON_SECRET
#   - GitHub: Settings → Secrets → Actions → CRON_SECRET
CRON_SECRET="your-secret-here"

# ─── Next Auth (optional — for user login) ────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="https://fiscus-peach.vercel.app"

# ─── Local dev only ───────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values

# ─── Premium voiceover (ElevenLabs) ───────────────────────────────────────────
# Optional. Without it, videos use the free browser voice. Get a key at:
# https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY="sk_..."
# Optional overrides:
#   ELEVENLABS_VOICE_ID  — force one voice for every story (else tone-matched)
#   ELEVENLABS_MODEL     — defaults to eleven_multilingual_v2
