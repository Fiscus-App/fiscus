# ─── Database ─────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (recommended)
# Get from: https://app.supabase.com → Project Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Authentication ────────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI ───────────────────────────────────────────────────────────────
# Anthropic Claude API key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Market Data ──────────────────────────────────────────────────────
# Alpha Vantage — free tier available: https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY="your-key-here"

# Polygon.io — for real-time ASX data: https://polygon.io
POLYGON_API_KEY="your-key-here"

# ─── Storage ──────────────────────────────────────────────────────────
# Supabase Storage for video assets and thumbnails
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-key"

# ─── Text-to-Speech (for AI voiceover) ────────────────────────────────
# ElevenLabs — https://elevenlabs.io
ELEVENLABS_API_KEY="your-key-here"
ELEVENLABS_VOICE_ID="your-voice-id"  # Professional finance voice

# ─── Video Rendering ──────────────────────────────────────────────────
# Remotion Lambda — https://www.remotion.dev/docs/lambda
REMOTION_AWS_REGION="ap-southeast-2"
REMOTION_FUNCTION_NAME="remotion-render-fiscus"
REMOTION_S3_BUCKET="fiscus-video-assets"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"

# ─── Background Jobs ──────────────────────────────────────────────────
# Inngest for background job processing — https://www.inngest.com
INNGEST_EVENT_KEY="your-event-key"
INNGEST_SIGNING_KEY="your-signing-key"

# ─── Feature flags ────────────────────────────────────────────────────
# Set to 'true' to enable real video rendering (else mocked)
ENABLE_VIDEO_RENDERING="false"
# Set to 'true' to enable live ingestion pipeline
ENABLE_INGESTION="false"
